# ============================================================
# 牛马归栏 NiuMaHome - 配置文件
# ============================================================
# 使用方法：
#   将本文件重命名为 .env.local（去掉 .example 后缀）
#   填入你自己的 API Key，然后双击"启动牛马归栏.bat"
#
# API Key 申请地址：
#   DeepSeek：https://platform.deepseek.com/api_keys
#   高德地图：https://console.amap.com/dev/key/app（Web服务类型）
#   百度地图：https://lbsyun.baidu.com/apiconsole/key（服务端类型）
#   链家Cookie：浏览器登录 gz.lianjia.com 后 F12 → Network → 复制Cookie
#   贝壳Cookie：浏览器登录 gz.zu.ke.com 后 F12 → Network → 复制Cookie
# ============================================================

# ── AI 大模型（必填，选一个）──────────────────────────────────
LLM_PROVIDER=deepseek

# DeepSeek（推荐，国内直连，¥1 ≈ 300次对话）
DEEPSEEK_API_KEY=你的DeepSeek_API_Key

# Claude（备用，需要海外网络）
# LLM_PROVIDER=claude
# ANTHROPIC_API_KEY=你的Anthropic_API_Key

# ── 地图 API（必填高德，百度可选）────────────────────────────
# 高德地图 Web服务 Key（必填，用于通勤精算）
AMAP_KEY=你的高德Key

# 百度地图（可选，高德失败时兜底）
# 申请时应用类型选"服务端"
BAIDU_AK=你的百度AK
# 如果使用SN签名校验方式（推荐），填SK；使用IP白名单方式则留空
BAIDU_SK=

# ── 平台 Cookie（可选，填了可以爬更多数据）───────────────────
# 浏览器登录后按 F12 → Network → 随便点一个请求 → 复制 Request Headers 里的 Cookie
LIANJIA_COOKIE=
BEIKE_COOKIE=
