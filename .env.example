# ==========================================
# 牛马归栏 (NiuMaHome) - 环境变量配置
# 复制此文件为 .env.local 后填入真实 Key
# 启动后端前确保 .env.local 存在于 backend/ 目录或项目根目录
# ==========================================

# ===== LLM 提供商选择 =====
# 可选值: deepseek (推荐，国内直连，便宜) / claude (海外，需要梯子+海外卡)
LLM_PROVIDER=deepseek

# ----- DeepSeek (推荐) -----
# 申请地址: https://platform.deepseek.com/api_keys
# 注册送 ¥10 额度，1 块钱可对话几百次
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ----- Anthropic Claude (可选) -----
# 申请地址: https://console.anthropic.com/
# 需要海外网络环境与海外信用卡
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# ===== 地图 API（三地图协同，合计 21000次/天免费） =====

# 高德 Web 服务: https://lbs.amap.com/dev/key
# 个人版免费 5000次/天，QPS=3
AMAP_KEY=xxx

# 腾讯地图 Web 服务: https://lbs.qq.com/dev/console/application/mine
# 个人版免费 10000次/天，域名白名单留空即可
TENCENT_KEY=xxx

# 百度地图 Web 服务: https://lbsyun.baidu.com/apiconsole/key
# 个人版免费 6000次/天
BAIDU_AK=xxx
BAIDU_SK=xxx

# ===== 平台 Cookie（可选，不填则无法抓取该平台数据） =====

# 链家: 打开 https://gz.lianjia.com/zufang/ 后按 F12 → Network
# 找任意 XHR 请求 → 复制 Request Headers 中的 Cookie 值
LIANJIA_COOKIE=

# 贝壳: 打开 https://gz.ke.com/zufang/ 同上操作
BEIKE_COOKIE=

# 安居客: 打开 https://gz.anjuke.com/zu/ 同上操作
ANJUKE_COOKIE=

# 58同城: JS渲染站点 + xxzl 指纹验证，httpx 无法绕过
# 需要在浏览器打开 https://gz.58.com/zufang/ 登录后复制 Cookie
# 不填则58同城 Tab 显示0条，其余平台不受影响
WUBA_COOKIE=

# ===== 服务配置 =====
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8001
FRONTEND_URL=http://localhost:3000

# ===== 数据库路径（相对 backend/ 目录）=====
DATABASE_URL=sqlite:///./data/niumahome.db

# ===== 日志级别 =====
LOG_LEVEL=INFO
